# EKS Cluster Configuration Template (legacy bash pipeline)
#
# This file is consumed by scripts/legacy/* (the deprecated bash deployment
# path). For new deployments use terraform/terraform.tfvars.example instead —
# see terraform/README.md and docs/MIGRATION_FROM_BASH.md.
#
# Copy this file to .env and fill in your values.
# DO NOT commit .env file to version control.

# ============================================
# Required Configuration
# ============================================

# EKS Cluster Name (must be unique in your AWS account)
CLUSTER_NAME=eks-demo-1

# VPC ID where the cluster will be deployed
VPC_ID=vpc-xxxxxxxxxxxxxxxxx

# Private Subnets (minimum 2 AZs required, supports 2-4 AZs)
PRIVATE_SUBNET_A=subnet-xxxxxxxxxxxxxxxxx
PRIVATE_SUBNET_B=subnet-xxxxxxxxxxxxxxxxx
# PRIVATE_SUBNET_C=subnet-xxxxxxxxxxxxxxxxx  # Optional: 3rd AZ
# PRIVATE_SUBNET_D=subnet-xxxxxxxxxxxxxxxxx  # Optional: 4th AZ

# Public Subnets (minimum 2 AZs required, supports 2-4 AZs)
PUBLIC_SUBNET_A=subnet-xxxxxxxxxxxxxxxxx
PUBLIC_SUBNET_B=subnet-xxxxxxxxxxxxxxxxx
# PUBLIC_SUBNET_C=subnet-xxxxxxxxxxxxxxxxx   # Optional: 3rd AZ
# PUBLIC_SUBNET_D=subnet-xxxxxxxxxxxxxxxxx   # Optional: 4th AZ

# ============================================
# Cluster Access Mode (Important)
# ============================================

# Cluster API endpoint access mode (default: private)
#
#   private  - API Server 仅在 VPC 内可访问（生产推荐）
#              · kubectl 必须从 VPC 内（堡垒机/VPN）执行
#              · 自动创建全部 VPC Endpoints，节点流量完全不出 VPC
#              · 满足 PCI-DSS、金融等严格合规要求
#
#   public   - API Server 同时开放公网 + VPC 私有访问
#              · kubectl 可从任意网络执行（开发 / 测试环境适用）
#              · 仅创建 minimal VPC Endpoints，节省约 $130-160/月（2AZ）
#              · 强烈建议配合 PUBLIC_ACCESS_CIDRS 限制来源 IP
#
# CLUSTER_MODE=private

# Restrict public API access to specific CIDR ranges (only when CLUSTER_MODE=public)
# Comma-separated list. Default: 0.0.0.0/0 (allow all, NOT recommended for production)
# Example: PUBLIC_ACCESS_CIDRS=203.0.113.0/24,198.51.100.0/24
# PUBLIC_ACCESS_CIDRS=0.0.0.0/0

# VPC Endpoints creation mode (default: auto-inferred from CLUSTER_MODE)
#
#   full     - 创建全部 13 个 Interface Endpoints + 1 个 S3 Gateway（private 模式默认）
#              估算成本：~$210/月（2AZ）
#
#   minimal  - 仅创建 EKS 节点注册必需的 4 个 Interface Endpoints + 1 个 S3 Gateway
#              (eks, eks-auth, sts, ec2 + s3-gateway)（public 模式默认）
#              估算成本：~$50/月（2AZ）；其余流量经 NAT Gateway 走公网
#
# VPC_ENDPOINTS_MODE=full

# ============================================
# Security Configuration (Recommended)
# ============================================

# KMS Key ARN for Secrets encryption (strongly recommended for production)
# If not set, secrets will be stored unencrypted in etcd
# You can create a key: aws kms create-key --description "EKS Secrets Encryption"
# KMS_KEY_ARN=arn:aws:kms:us-west-2:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Enable cluster deletion protection (default: true)
# Prevents accidental cluster deletion
ENABLE_DELETION_PROTECTION=true

# ============================================
# Optional Configuration (will be auto-detected if not set)
# ============================================

# AWS Account ID (auto-detected from AWS CLI if not set)
# ACCOUNT_ID=123456789012

# AWS Region (auto-detected from AWS CLI if not set)
AWS_REGION=eu-central-1
AWS_DEFAULT_REGION=eu-central-1

# Kubernetes Version (default: 1.35)
# K8S_VERSION=1.35

# Kubernetes Service IPv4 CIDR (default: 172.20.0.0/16)
# Important: Must not overlap with VPC CIDR
# SERVICE_IPV4_CIDR=172.20.0.0/16

# Availability Zones (auto-derived from region if not set)
# AZ_A=eu-central-1a
# AZ_B=eu-central-1b
# AZ_C=eu-central-1c   # Optional: only needed if using 3+ AZs
# AZ_D=eu-central-1d   # Optional: only needed if using 4 AZs

# ============================================
# How to use this file
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Run the legacy deployment scripts (in order, from the bastion host):
#       source scripts/0_setup_env.sh
#       ./scripts/legacy/1_enable_vpc_dns.sh
#       ./scripts/legacy/3_create_vpc_endpoints.sh
#       ./scripts/legacy/4_install_eks_cluster.sh
#       ./scripts/legacy/6_create_system_nodegroup.sh
#       ./scripts/legacy/7_install_eks_addon.sh
#    See docs/DEPLOYMENT_SOP.md for the legacy procedure.
#    For new deployments use terraform/ instead — see terraform/README.md.
#
# 0_setup_env.sh will automatically:
# - Load configuration from .env
# - Auto-detect AWS Account ID if not provided
# - Auto-detect AWS Region from AWS CLI config
# - Validate VPC and subnets exist
# - Set reasonable defaults for optional values

# ============================================
# System Nodegroup Configuration (Advanced)
# ============================================

# System nodegroup instance type (default: m8g.xlarge - Graviton4 ARM64)
# Supports both ARM64 (m8g, m7g, c7g, r7g, t4g) and x86_64 (m7i, c7i, r7i)
# Script auto-detects architecture and selects correct AMI
# SYSTEM_NODE_INSTANCE_TYPE=m8g.xlarge

# System nodegroup volume sizes
# SYSTEM_NODE_ROOT_VOLUME_SIZE=50    # Root volume size (GB)
# SYSTEM_NODE_DATA_VOLUME_SIZE=100   # Data volume size (GB, for LVM)

# System nodegroup capacity
# SYSTEM_NODE_DESIRED_CAPACITY=3
# SYSTEM_NODE_MIN_SIZE=3
# SYSTEM_NODE_MAX_SIZE=6

# System nodegroup label for scheduling system components
# This label is used by all addons to ensure they run on system nodes
# SYSTEM_NODE_LABEL_KEY=app
# SYSTEM_NODE_LABEL_VALUE=eks-utils

# EC2 Key Pair for SSH access to nodes (optional)
# If not set, use SSM Session Manager for node access
# Note: Key name is case-sensitive, must match exactly as shown in AWS console
# Note: Applies to system nodegroup and GPU nodegroups (Managed Node Groups with Launch Templates)
# EC2_KEY_NAME=my-eks-key

# SSH Public Key for Karpenter nodes (optional)
# Since Karpenter v1 doesn't support keyPair field, use this to inject SSH public key via userData
# Get your public key: cat ~/.ssh/id_rsa.pub
# IMPORTANT: The value MUST be quoted because ssh public keys contain spaces.
# SSH_PUBLIC_KEY="ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAAB... user@host"

# Notes:
# 1. System nodegroup runs cluster core components (coredns, aws-load-balancer-controller, etc.)
# 2. Uses LVM configuration, containerd data stored on separate 100GB data volume
# 3. Changes to these settings require recreating the cluster
# 4. Default values are suitable for most use cases
# 5. If you change SYSTEM_NODE_LABEL_*, all addons will automatically use the new label

# ============================================
# Storage Configuration (Advanced)
# ============================================
# Note: gp3 and io2 StorageClasses are always installed by default
# You can customize io2 IOPS if needed

# IO2_IOPS=10000                     # IOPS for io2 volumes (100-64000, default: 10000)

# ============================================
# Component Version Configuration (Advanced)
# ============================================
# Override default component versions if needed
# Check compatibility before changing versions

# Core Addon Versions (components not available as EKS Managed Addons)
# CLUSTER_AUTOSCALER_VERSION=v1.35.0   # Must match K8S_VERSION major.minor
# ALB_CONTROLLER_VERSION=v2.14.1       # AWS Load Balancer Controller app version
# ALB_CONTROLLER_CHART_VERSION=1.16.0  # Helm chart version

# Karpenter Version
# KARPENTER_VERSION=1.12.1              # Karpenter node provisioner version

# Bastion tool versions (pinned so bastion builds are reproducible and
# supply-chain attacks against floating `latest`/`main` can't execute).
# Used only by scripts/option_create_bastion.sh.
# EKSCTL_VERSION=v0.226.0               # eksctl CLI version (must support your K8S_VERSION)
# HELM_VERSION=v3.17.3                  # helm CLI version

# Note: CoreDNS, Metrics Server, and CSI Driver (EBS, EFS, FSx, S3) versions
# are managed by EKS Managed Addons and automatically selected by AWS for the
# installed EKS version. No manual version configuration needed.

# ============================================
# Optional EKS Components Configuration
# ============================================

# Auto-scaling Options
# INSTALL_KARPENTER=false            # Install Karpenter node provisioner (default: false)

# GPU Managed Node Groups (for option_install_gpu_nodegroups.sh)
# Uses AWS Managed Node Groups with Launch Templates for EFA multi-NIC support
# GPU_INSTANCE_TYPES=p5.48xlarge,p5en.48xlarge,p6-b200.48xlarge,p6-b300.48xlarge,g7e.48xlarge  # GPU types to deploy (comma-separated)
# GPU_NODE_DESIRED_CAPACITY=0        # Initial node count per nodegroup
# GPU_NODE_MIN_SIZE=0                # Minimum nodes per nodegroup
# GPU_NODE_MAX_SIZE=8                # Maximum nodes per nodegroup
# GPU_NODE_ROOT_VOLUME_SIZE=50       # Root volume size (GB)
# GPU_NODE_DATA_VOLUME_SIZE=100      # Data volume for LVM (GB)

# GPU Pricing Options (mutually exclusive - choose ONE)
# These are separate deployment modes, not combinations:
#   - OD:   Standard on-demand pricing
#   - Spot: Best for fault-tolerant, cost-sensitive workloads
#   - ODCR: Guaranteed capacity with on-demand pricing
#   - CB:   Time-limited reserved capacity for scheduled workloads
# DEPLOY_GPU_OD=false                # Deploy On-Demand GPU node groups
# DEPLOY_GPU_SPOT=true               # Deploy Spot GPU node groups (default)
# DEPLOY_GPU_ODCR=false              # Deploy ODCR GPU node groups (requires ODCR_ID)
# DEPLOY_GPU_CB=false                # Deploy Capacity Block GPU node groups (requires CB_ID)

# ODCR Configuration (only when DEPLOY_GPU_ODCR=true)
# Supports multiple ODCRs: use comma-separated lists (same length required)
# Each ODCR creates a separate node group with suffix -1, -2, etc.
# ODCR_IDS=cr-123,cr-456            # On-Demand Capacity Reservation IDs (comma-separated)
# ODCR_AZS=us-east-1a,us-east-1b    # Corresponding AZs (comma-separated, same order)
# Legacy single-value format also supported:
# ODCR_ID=cr-123                    # Single ODCR ID
# ODCR_AZ=us-east-1a                # Single AZ

# Capacity Block Configuration (only when DEPLOY_GPU_CB=true)
# Supports multiple CBs: use comma-separated lists (same length required)
# Each CB creates a separate node group with suffix -1, -2, etc.
# CAPACITY_BLOCK_IDS=cr-789,cr-012  # Capacity Block reservation IDs (comma-separated)
# CAPACITY_BLOCK_AZS=us-east-1a,us-east-1c  # Corresponding AZs (comma-separated, same order)
# Legacy single-value format also supported:
# CAPACITY_BLOCK_ID=cr-789          # Single CB ID
# CAPACITY_BLOCK_AZ=us-east-1a      # Single AZ

# EFA Interface Counts (auto-configured based on instance type):
#   P-family (multi-NIC EFA):
#     - p5.48xlarge:        32 ENIs (1 primary + 31 EFA-only)
#     - p5en.48xlarge:      16 ENIs (1 primary + 15 EFA-only)
#     - p6-b200.48xlarge:    8 ENIs (1 primary + 7 EFA-only)
#     - p6-b300.48xlarge:   17 ENIs (NIC0 = ENA only + 16 EFA-only)
#   G6e (L40S):
#     - g6e.8/12/16xlarge:   1 ENI (single NIC, EFA on NIC0)
#     - g6e.24xlarge:        2 ENIs (1 primary + 1 EFA-only)
#     - g6e.48xlarge:        4 ENIs (1 primary + 3 EFA-only)
#   G7e (RTX PRO 6000 Blackwell, EFAv4):
#     - g7e.8/12xlarge:      1 ENI (single NIC, EFA on NIC0)
#     - g7e.24xlarge:        2 ENIs (1 primary + 1 EFA-only)
#     - g7e.48xlarge:        4 ENIs (1 primary + 3 EFA-only)

# EFA userspace (libfabric-aws + openmpi5-aws + fi_info diagnostics):
# The EKS GPU AMI ships only kernel-side EFA; userdata fetches the
# installer tarball from https://efa-installer.amazonaws.com at first boot.
# GPU_INSTALL_EFA_USERSPACE=true        # Install /opt/amazon/efa/ on the host (default: true)
# GPU_EFA_INSTALLER_VERSION=1.48.0      # Pin tarball version for reproducible bringup (default: 1.48.0)
                                        # Empty = "latest" (rolls forward, do not use in production)

# ============================================
# K8s GPU Stack (option_install_gpu_stack.sh)
# ============================================
# Two mutually-exclusive modes — pick ONE.
#
#   standard (default):
#     • nvidia-device-plugin (exposes nvidia.com/gpu)
#     • aws-efa-k8s-device-plugin (exposes vpc.amazonaws.com/efa)
#     • dcgm-exporter (Prometheus GPU metrics)
#     • node-problem-detector (NodeCondition for XID errors)
#     • gpu-health-check (boot-time nvidia-smi probe + auto-taint)
#
#   operator:
#     • NVIDIA GPU Operator (driver/toolkit/mofed DISABLED to coexist
#                            with EKS GPU AMI + AWS EFA plugin)
#     • aws-efa-k8s-device-plugin (still installed by us)
#
# Conflict points the mode selector prevents (kept here for future readers):
#   - nvidia.com/gpu registration: helm device-plugin vs Operator's plugin DS
#   - port 9400: helm dcgm-exporter vs Operator's nvidia-dcgm-exporter
#   - GFD labels: chart-internal GFD vs Operator's GFD DS
#   - /dev/infiniband/uverbs*: mofedDriver vs AWS EFA plugin
#
# Switch modes later with:
#   GPU_STACK_MODE=<other> GPU_STACK_FORCE_SWITCH=true bash scripts/legacy/option_install_gpu_stack.sh
#
# GPU_STACK_MODE=standard               # standard | operator (default: standard)

# --- Shared (both modes) ---
# INSTALL_EFA_DEVICE_PLUGIN=true        # Install aws-efa-k8s-device-plugin DaemonSet (default: true)
# EFA_DEVICE_PLUGIN_VERSION=v0.5.19     # EFA plugin image tag (default: v0.5.19)
# EFA_DEVICE_PLUGIN_IMAGE=              # Full image override (CN regions or private mirror)
                                        # e.g. 123456789012.dkr.ecr.cn-northwest-1.amazonaws.com.cn/mirror/aws-efa-k8s-device-plugin:v0.5.17

# --- standard mode ---
# NVIDIA_DEVICE_PLUGIN_VERSION=v0.19.1  # Plugin image tag (default: v0.19.1)
# NVIDIA_DEVICE_PLUGIN_REPO=            # Image repo override (CN regions where nvcr.io is unreachable)
                                        # e.g. 123456789012.dkr.ecr.cn-northwest-1.amazonaws.com.cn/mirror/k8s-device-plugin
# INSTALL_DCGM_EXPORTER=true            # Pod-level GPU metrics for Prometheus (default: true)
# DCGM_EXPORTER_VERSION=4.8.2           # dcgm-exporter chart version (chart repo: nvidia.github.io/dcgm-exporter/helm-charts, NOT NGC)
# INSTALL_NODE_PROBLEM_DETECTOR=true    # Surface XID/kernel issues as NodeConditions (default: true)
# NPD_VERSION=2.3.14                    # node-problem-detector chart version
# INSTALL_GPU_HEALTH_CHECK=true         # Boot-time nvidia-smi self-test + auto taint (default: true)

# --- operator mode ---
# GPU_OPERATOR_VERSION=v25.3.4          # NVIDIA GPU Operator chart version
# GPU_OPERATOR_NAMESPACE=gpu-operator   # default: gpu-operator
# GPU_OPERATOR_DRIVER_ENABLED=false     # MUST stay false on EKS GPU AMI (AMI ships driver)
# GPU_OPERATOR_TOOLKIT_ENABLED=false    # MUST stay false on EKS GPU AMI (AMI ships toolkit)
# GPU_OPERATOR_MOFED_ENABLED=false      # MUST stay false (AWS EFA owns /dev/infiniband/uverbs*)
# GPU_OPERATOR_MIG_STRATEGY=none        # none | single | mixed (only A100/H100 multi-tenancy needs single|mixed)

# Mutual-exclusion: switching modes refuses by default if the other mode's
# helm releases or namespaces exist. Override with:
# GPU_STACK_FORCE_SWITCH=true           # Auto-uninstall conflicting releases before installing

# File System Options
# INSTALL_EFS_CSI=false              # Install EFS CSI Driver for shared file systems (default: false)
# INSTALL_FSX_CSI=false              # Install FSx CSI Driver for Lustre/ONTAP workloads (default: false)

# Note: S3 CSI Driver should be installed separately using scripts/legacy/option_install_csi_drivers.sh
# with specific bucket ARNs for production security
#
# Supported S3 bucket types:
#   - Standard S3: General purpose buckets (arn:aws:s3:::bucket-name)
#   - S3 Express One Zone: Low-latency directory buckets (arn:aws:s3express:region:account:bucket/name--zone-id--x-s3)
#   - Mixed: Can specify both types (script auto-detects and creates appropriate IAM policies)

# ============================================
# Component Installation Summary
# ============================================
#
# Always Installed (Mandatory):
#   - EBS CSI Driver: Block storage for persistent volumes
#   - StorageClasses: gp3 (default), io2 (high-performance)
#   - Metrics Server: Required for HPA/VPA and kubectl top
#   - Cluster Autoscaler: Basic node auto-scaling
#   - AWS Load Balancer Controller: Ingress/Service load balancing
#
# Optional Components (Set flags above to enable):
#   - Karpenter: Advanced node provisioner (can coexist with Cluster Autoscaler)
#   - EFS CSI: Shared file system across pods/nodes
#   - FSx CSI: High-performance Lustre for HPC/ML workloads
#   - S3 CSI: Use dedicated script with specific bucket ARNs
#
# Storage Class Usage:
#   - gp3: General purpose, cost-effective (20% cheaper than gp2, 3000 IOPS baseline)
#   - io2: High-performance for databases (configurable IOPS 100-64000)
